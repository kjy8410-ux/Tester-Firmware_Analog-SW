// =====================================================
// STATE
// =====================================================
enum State {
  INIT,
  IDLE,
  DIN_ON,
  TEST_RUNNING,
  ESTOP
};

State state = INIT;
unsigned long stateTime = 0;

bool leftFail  = false;
bool rightFail = false;

// =====================================================
// LOW LEVEL : LEB / SERIAL SHIFT
// =====================================================
void setLebIdle(uint8_t pin) {
  digitalWrite(pin, LEB_ACTIVE_LOW ? HIGH : LOW);
}

void setLebActive(uint8_t pin) {
  digitalWrite(pin, LEB_ACTIVE_LOW ? LOW : HIGH);
}

void pulseLeb(uint8_t pin) {
  setLebActive(pin);
  delayMicroseconds(LEB_PULSE_US);
  setLebIdle(pin);
  delayMicroseconds(LEB_PULSE_US);
}

void sendOneBit(bool bitValue) {
  digitalWrite(PIN_DIN_DATA, bitValue ? HIGH : LOW);
  delayMicroseconds(SERIAL_PULSE_US);

  digitalWrite(PIN_DIN_CLK, HIGH);
  delayMicroseconds(SERIAL_PULSE_US);
  digitalWrite(PIN_DIN_CLK, LOW);
  delayMicroseconds(SERIAL_PULSE_US);
}

void writeZoneFromProgmem(uint8_t lebPin, const uint8_t* bits, uint16_t count) {
  if (SEND_LAST_TO_FIRST) {
    for (int32_t i = (int32_t)count - 1; i >= 0; i--) {
      bool tableBit = pgm_read_byte(&bits[i]);
      bool sendBit = tableBit ? SWITCH_ON_BIT : !SWITCH_ON_BIT;
      sendOneBit(sendBit);
    }
  } else {
    for (uint16_t i = 0; i < count; i++) {
      bool tableBit = pgm_read_byte(&bits[i]);
      bool sendBit = tableBit ? SWITCH_ON_BIT : !SWITCH_ON_BIT;
      sendOneBit(sendBit);
    }
  }

  pulseLeb(lebPin);
}

void writeZoneAllOff(uint8_t lebPin, uint16_t count) {
  for (uint16_t i = 0; i < count; i++) {
    bool sendBit = !SWITCH_ON_BIT;
    sendOneBit(sendBit);
  }
  pulseLeb(lebPin);
}

void setSelectedSwitches() {
  writeZoneFromProgmem(PIN_LEB_LU, BITS_LU_BITS, BITS_LU_COUNT);
  writeZoneFromProgmem(PIN_LEB_LD, BITS_LD_BITS, BITS_LD_COUNT);
  writeZoneFromProgmem(PIN_LEB_RU, BITS_RU_BITS, BITS_RU_COUNT);
  writeZoneFromProgmem(PIN_LEB_RD, BITS_RD_BITS, BITS_RD_COUNT);
}

void clearAllSwitches() {
  writeZoneAllOff(PIN_LEB_LU, BITS_LU_COUNT);
  writeZoneAllOff(PIN_LEB_LD, BITS_LD_COUNT);
  writeZoneAllOff(PIN_LEB_RU, BITS_RU_COUNT);
  writeZoneAllOff(PIN_LEB_RD, BITS_RD_COUNT);
}

// =====================================================
// MUX
// =====================================================
void setMuxAddr(uint8_t a) {
  digitalWrite(PIN_MUX_S0, a & 1);
  digitalWrite(PIN_MUX_S1, a & 2);
  digitalWrite(PIN_MUX_S2, a & 4);
  digitalWrite(PIN_MUX_S3, a & 8);
}

void setLeftBank(uint8_t b) {
  digitalWrite(PIN_MUX_SEL_L0, b & 1);
  digitalWrite(PIN_MUX_SEL_L1, b & 2);
  digitalWrite(PIN_MUX_SEL_L2, b & 4);
}

void setRightBank(uint8_t b) {
  digitalWrite(PIN_MUX_SEL_R0, b & 1);
  digitalWrite(PIN_MUX_SEL_R1, b & 2);
  digitalWrite(PIN_MUX_SEL_R2, b & 4);
}

void parkLeft()  { setLeftBank(7); }
void parkRight() { setRightBank(7); }

// =====================================================
// ADC
// =====================================================
int readADC() {
  long sum = 0;
  for (int i = 0; i < 8; i++) {
    sum += analogRead(PIN_ADC);
    delayMicroseconds(200);
  }
  return sum / 8;
}

// =====================================================
// SCAN
// =====================================================
bool scanLeft() {
  parkRight();
  bool fail = false;

  for (int b = 0; b < 6; b++) {
    setLeftBank(b);
    for (int a = 0; a < 16; a++) {
      setMuxAddr(a);
      delayMicroseconds(MUX_SETTLE_US);

      int v = readADC();
      int ch = b * 16 + a;

      if (v > adcOkMaxLeft) {
        fail = true;
        if (SERIAL_DEBUG) {
          Serial.print("[FAIL][LEFT] CH=");
          Serial.print(ch);
          Serial.print(" (BANK=");
          Serial.print(b);
          Serial.print(" ADDR=");
          Serial.print(a);
          Serial.print(") ADC=");
          Serial.println(v);
        }
      }
    }
  }
  return fail;
}

bool scanRight() {
  parkLeft();
  bool fail = false;

  for (int b = 0; b < 7; b++) {
    setRightBank(b);
    for (int a = 0; a < 16; a++) {
      setMuxAddr(a);
      delayMicroseconds(MUX_SETTLE_US);

      int v = readADC();
      int ch = b * 16 + a;

      if (v > adcOkMaxRight) {
        fail = true;
        if (SERIAL_DEBUG) {
          Serial.print("[FAIL][RIGHT] CH=");
          Serial.print(ch);
          Serial.print(" (BANK=");
          Serial.print(b);
          Serial.print(" ADDR=");
          Serial.print(a);
          Serial.print(") ADC=");
          Serial.println(v);
        }
      }
    }
  }
  return fail;
}

// =====================================================
// SERIAL COMMAND
// =====================================================
void printStatus() {
  Serial.println("===== STATUS =====");
  Serial.print("LU count = "); Serial.println(BITS_LU_COUNT);
  Serial.print("LD count = "); Serial.println(BITS_LD_COUNT);
  Serial.print("RU count = "); Serial.println(BITS_RU_COUNT);
  Serial.print("RD count = "); Serial.println(BITS_RD_COUNT);
  Serial.print("TOTAL    = "); Serial.println((uint32_t)BITS_LU_COUNT + BITS_LD_COUNT + BITS_RU_COUNT + BITS_RD_COUNT);
  Serial.println("Command: ON / OFF / TEST / STATUS");
}

void handleSerialCommand() {
  if (!Serial.available()) return;

  String cmd = Serial.readStringUntil('
');
  cmd.trim();
  cmd.toUpperCase();

  if (cmd == "ON") {
    setSelectedSwitches();
    state = DIN_ON;
    Serial.println("SWITCH PATTERN ON");
  } else if (cmd == "OFF") {
    clearAllSwitches();
    state = IDLE;
    Serial.println("ALL SWITCH OFF");
  } else if (cmd == "TEST") {
    setSelectedSwitches();
    state = TEST_RUNNING;
    stateTime = millis();
    Serial.println("TEST START");
  } else if (cmd == "STATUS") {
    printStatus();
  } else if (cmd.length() > 0) {
    Serial.print("UNKNOWN COMMAND: ");
    Serial.println(cmd);
    Serial.println("Use: ON / OFF / TEST / STATUS");
  }
}

// =====================================================
// LED
// =====================================================
void updateLED() {
  digitalWrite(PIN_LED_IDLE,  LED_OFF);
  digitalWrite(PIN_LED_DINON, LED_OFF);
  digitalWrite(PIN_LED_TEST,  LED_OFF);
  digitalWrite(PIN_LED_LEFT,  LED_OFF);
  digitalWrite(PIN_LED_RIGHT, LED_OFF);
  digitalWrite(PIN_LED_ESTOP, LED_OFF);

  switch (state) {
    case IDLE:
      digitalWrite(PIN_LED_IDLE, LED_ON);
      if (leftFail)  digitalWrite(PIN_LED_LEFT, LED_ON);
      if (rightFail) digitalWrite(PIN_LED_RIGHT, LED_ON);
      break;

    case DIN_ON:
      digitalWrite(PIN_LED_DINON, LED_ON);
      break;

    case TEST_RUNNING:
      digitalWrite(PIN_LED_TEST, LED_ON);
      break;

    case ESTOP:
      digitalWrite(PIN_LED_ESTOP, LED_ON);
      break;

    default:
      break;
  }
}

// =====================================================
// SETUP
// =====================================================
void setup() {
  if (SERIAL_DEBUG) {
    Serial.begin(SERIAL_BAUD);
    delay(500);
    Serial.println("SYSTEM START");
  }

  pinMode(PIN_LED_IDLE, OUTPUT);
  pinMode(PIN_LED_DINON, OUTPUT);
  pinMode(PIN_LED_TEST, OUTPUT);
  pinMode(PIN_LED_LEFT, OUTPUT);
  pinMode(PIN_LED_RIGHT, OUTPUT);
  pinMode(PIN_LED_ESTOP, OUTPUT);

  pinMode(PIN_BTN_DIN_ON, INPUT_PULLUP);
  pinMode(PIN_BTN_DIN_OFF, INPUT_PULLUP);
  pinMode(PIN_BTN_TEST, INPUT_PULLUP);
  pinMode(PIN_BTN_ESTOP, INPUT_PULLUP);

  pinMode(PIN_LEB_LU, OUTPUT);
  pinMode(PIN_LEB_LD, OUTPUT);
  pinMode(PIN_LEB_RU, OUTPUT);
  pinMode(PIN_LEB_RD, OUTPUT);
  pinMode(PIN_DIN_DATA, OUTPUT);
  pinMode(PIN_DIN_CLK, OUTPUT);

  pinMode(PIN_MUX_S0, OUTPUT);
  pinMode(PIN_MUX_S1, OUTPUT);
  pinMode(PIN_MUX_S2, OUTPUT);
  pinMode(PIN_MUX_S3, OUTPUT);
  pinMode(PIN_MUX_SEL_L0, OUTPUT);
  pinMode(PIN_MUX_SEL_L1, OUTPUT);
  pinMode(PIN_MUX_SEL_L2, OUTPUT);
  pinMode(PIN_MUX_SEL_R0, OUTPUT);
  pinMode(PIN_MUX_SEL_R1, OUTPUT);
  pinMode(PIN_MUX_SEL_R2, OUTPUT);

  digitalWrite(PIN_DIN_DATA, LOW);
  digitalWrite(PIN_DIN_CLK, LOW);

  setLebIdle(PIN_LEB_LU);
  setLebIdle(PIN_LEB_LD);
  setLebIdle(PIN_LEB_RU);
  setLebIdle(PIN_LEB_RD);

  clearAllSwitches();
  parkLeft();
  parkRight();

  state = IDLE;
  printStatus();
}

// =====================================================
// LOOP
// =====================================================
void loop() {
  handleSerialCommand();

  if (!digitalRead(PIN_BTN_ESTOP)) {
    state = ESTOP;
    stateTime = millis();
  }

  switch (state) {
    case IDLE:
      if (!digitalRead(PIN_BTN_DIN_ON)) {
        setSelectedSwitches();
        state = DIN_ON;
        delay(200);
      }

      if (!digitalRead(PIN_BTN_TEST)) {
        setSelectedSwitches();
        state = TEST_RUNNING;
        stateTime = millis();
        if (SERIAL_DEBUG) Serial.println("TEST START");
        delay(200);
      }
      break;

    case DIN_ON:
      if (!digitalRead(PIN_BTN_DIN_OFF)) {
        clearAllSwitches();
        state = IDLE;
        delay(200);
      }
      break;

    case TEST_RUNNING:
      if (millis() - stateTime >= TEST_DELAY_MS) {
        leftFail  = scanLeft();
        rightFail = scanRight();

        if (SERIAL_DEBUG) Serial.println("TEST END");

        clearAllSwitches();
        state = IDLE;
      }
      break;

    case ESTOP:
      clearAllSwitches();
      if (millis() - stateTime > 5000) {
        state = IDLE;
      }
      break;

    default:
      state = IDLE;
      break;
  }

  updateLED();
}
